<% layout("layouts/boilerplate") -%>

<script>
  const mapToken = "<%= process.env.MAPBOX_TOKEN %>";
  const coordinates = <%- JSON.stringify(
    listing && listing.geometry ? listing.geometry.coordinates : []
  ) %>;
</script>


<div class="row mt-3">
  <div class="col-8 offset-3">
    <h3><%= listing && listing.title ? listing.title : 'Untitled' %></h3>
  </div>

  <div class="card col-6 offset-3 show-card listing-card">
    <img
      src="<%= (listing && listing.image) 
         ? (typeof listing.image === 'string' ? listing.image : listing.image.url || '/images/default.jpg')
         : '/images/default.jpg' %>"


      class="card-img-top show-img"
      alt="listing_image"
      style="object-fit: cover;"
    />
    <div class="card-body">
      <p class="card-text">
        Owned By <i><%= listing && listing.owner ? (listing.owner.username || 'Unknown') : 'Unknown' %></i>
      </p>
      <p class="card-text"><%= listing && listing.description ? listing.description : '' %></p>
      <p class="card-text">
        &#8377;
        <%= (typeof listing.price === 'number' || (!isNaN(Number(listing.price)) && listing.price !== undefined))
            ? Number(listing.price).toLocaleString("en-IN")
            : '—' %>
      </p>
      <p class="card-text"><%= listing && listing.location ? listing.location : '' %></p>
      <p class="card-text"><%= listing && listing.country ? listing.country : '' %></p>
    </div>
  </div>

  <% if (currUser && listing && listing.owner && String(listing.owner._id) === String(currUser._id)) { %>
    <div class="btns" style="margin-top: 0.75rem;">
      <a href="/listings/<%= listing._id %>/edit" class="btn btn-dark col-1 offset-3 edit-btn">Edit</a>

      <form action="/listings/<%= listing._id %>?_method=DELETE" method="POST" style="display:inline-block; margin-left:10px;">
        <button class="btn btn-dark delete-btn">Delete</button>
      </form>
    </div>
  <% } %>

  <div class="col-8 offset-3 mb-3" style="margin-top:1.5rem;">
    <% if (currUser) { %>
      <hr />
      <h4>Leave a review</h4>
      <form action="/listings/<%= listing._id %>/reviews" method="POST" novalidate class="needs-validation">
        <div class="mb-3 mt-3">
          <label for="rating" class="form-label">Rating</label>
          <fieldset class="starability-slot">
            <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" value="1" checked aria-label="No rating." />
            <input type="radio" id="first-rate1" name="review[rating]" value="1" />
            <label for="first-rate1" title="Terrible">1 star</label>
            <input type="radio" id="first-rate2" name="review[rating]" value="2" />
            <label for="first-rate2" title="Not good">2 stars</label>
            <input type="radio" id="first-rate3" name="review[rating]" value="3" />
            <label for="first-rate3" title="Average">3 stars</label>
            <input type="radio" id="first-rate4" name="review[rating]" value="4" />
            <label for="first-rate4" title="Very good">4 stars</label>
            <input type="radio" id="first-rate5" name="review[rating]" value="5" />
            <label for="first-rate5" title="Amazing">5 stars</label>
          </fieldset>
        </div>

        <div class="mb-3 mt-3">
          <label for="comment" class="form-label">Comment</label>
          <textarea name="review[comment]" id="comment" cols="30" rows="5" class="form-control" required></textarea>
          <div class="invalid-feedback">Please add some comments for review</div>
        </div>

        <button class="btn btn-outline-dark">Submit</button>
      </form>
      <hr />
    <% } %>

    <% if (listing && listing.reviews && listing.reviews.length > 0) { %>
      <div class="row">
        <p><b>All Reviews</b></p>
        <% for (let review of listing.reviews) { %>
          <div class="card col-5 ms-3 mb-3">
            <div class="card-body">
              <h5 class="card-title">@<%= review && review.author ? (review.author.username || 'Anonymous') : 'Anonymous' %></h5>
              <p class="starability-result card-text" data-rating="<%= review.rating %>"></p>
              <p class="card-text"><%= review.comment %></p>

              <form action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE" class="mb-3" method="POST">
                <button class="btn btn-sm btn-dark">Delete</button>
              </form>
            </div>
          </div>
        <% } %>
      </div>
    <% } %>
  </div>

  <div class="col-8 offset-3 mb-3">
    <h3>Where you'll be</h3>
    <div id="map" style="height:350px; border-radius:6px;"></div>
  </div>
</div>

<script src="/js/map.js"></script>
